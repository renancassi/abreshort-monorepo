    "@fastify/swagger": "^9.7.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^6.19.2",
    "@scalar/fastify-api-reference": "^1.46.4",
    "dotenv": "^17.3.1",
    "fastify": "5.8.2",
    "fastify-type-provider-zod": "^6.1.0",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
